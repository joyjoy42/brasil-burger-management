{% extends 'base.html.twig' %}

{% block title %}{{ burger.nom }} - Brasil Burger{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Détails du burger: {{ burger.nom }}</h1>
        <a href="{{ path('app_burger_index') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour à la liste
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            {% if burger.image %}
                                <img src="{{ asset(burger.image) }}" alt="{{ burger.nom }}" class="img-fluid rounded">
                            {% else %}
                                <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 200px;">
                                    <span class="text-muted">Pas d'image</span>
                                </div>
                            {% endif %}
                        </div>
                        <div class="col-md-8">
                            <h3>{{ burger.nom }}</h3>
                            <p class="text-primary fs-4">{{ burger.prix|number_format(0, ',', ' ') }} FCFA</p>
                            
                            <div class="mb-3">
                                <strong>Statut:</strong>
                                {% if burger.archive %}
                                    <span class="badge bg-secondary">Archivé</span>
                                {% else %}
                                    <span class="badge bg-success">Actif</span>
                                {% endif %}
                            </div>

                            {% if burger.image %}
                                <div class="mb-3">
                                    <strong>URL de l'image:</strong><br>
                                    <code>{{ burger.image }}</code>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5>Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="{{ path('app_burger_edit', {'id': burger.id}) }}" class="btn btn-warning">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                        {% if burger.archive %}
                            <form method="post" action="{{ path('app_burger_unarchive', {'id': burger.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('unarchive' ~ burger.id) }}">
                                <button type="submit" class="btn btn-success w-100" onclick="return confirm('Êtes-vous sûr de vouloir désarchiver ce burger?')">
                                    <i class="fas fa-undo"></i> Désarchiver
                                </button>
                            </form>
                        {% else %}
                            <form method="post" action="{{ path('app_burger_archive', {'id': burger.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('archive' ~ burger.id) }}">
                                <button type="submit" class="btn btn-secondary w-100" onclick="return confirm('Êtes-vous sûr de vouloir archiver ce burger?')">
                                    <i class="fas fa-archive"></i> Archiver
                                </button>
                            </form>
                        {% endif %}
                        <form method="post" action="{{ path('app_burger_delete', {'id': burger.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ burger.id) }}">
                            <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Êtes-vous sûr de vouloir supprimer ce burger? Cette action est irréversible.')">
                                <i class="fas fa-trash"></i> Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
