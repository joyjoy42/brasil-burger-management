{% extends 'base.html.twig' %}

{% block title %}Gestion du Catalogue - Brasil Burger Admin{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row">
        <!-- Sidebar -->
        <nav class="col-md-3 col-lg-2 d-md-block bg-light sidebar collapse shadow-sm">
            <div class="position-sticky pt-3">
                <ul class="nav flex-column">
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_dashboard') }}"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_order_index') }}"><i class="bi bi-bag"></i> Commandes</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_delivery_index') }}"><i class="bi bi-truck"></i> Livraisons</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_stats_index') }}"><i class="bi bi-graph-up"></i> Statistiques</a></li>
                    <li class="nav-item"><a class="nav-link active" href="{{ path('app_catalog_index') }}"><i class="bi bi-journal-list"></i> Catalogue</a></li>
                </ul>
            </div>
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Gestion du Catalogue</h1>
                <div class="btn-group">
                    <a href="{{ path('app_catalog_burger_new') }}" class="btn btn-sm btn-primary">+ Burger</a>
                </div>
            </div>

            <div class="row">
                <!-- Burgers -->
                <div class="col-12 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white"><strong>Burgers</strong></div>
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead class="table-light"><tr><th>Nom</th><th>Prix</th><th>Statut</th></tr></thead>
                                <tbody>
                                    {% for b in burgers %}
                                        <tr>
                                            <td>{{ b.name }}</td>
                                            <td>{{ b.price }} FCFA</td>
                                            <td>{{ b.archived ? 'Inactif' : 'Actif' }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}
