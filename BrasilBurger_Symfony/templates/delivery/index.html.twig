{% extends 'base.html.twig' %}

{% block title %}Gestion des Livraisons{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row">
        <!-- Sidebar -->
        <nav class="col-md-3 col-lg-2 d-md-block bg-light sidebar collapse shadow-sm">
            <div class="position-sticky pt-3">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_dashboard') }}">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_order_index') }}">
                            <i class="bi bi-bag"></i> Commandes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="{{ path('app_delivery_index') }}">
                            <i class="bi bi-truck"></i> Livraisons
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_stats_index') }}">
                            <i class="bi bi-graph-up"></i> Statistiques
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_catalog_index') }}">
                            <i class="bi bi-journal-list"></i> Catalogue
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Commandes à Livrer</h1>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            <div class="row">
                {% for zone in zones %}
                    <div class="col-md-6 mb-4">
                        <div class="card shadow-sm h-100">
                            <div class="card-header bg-dark text-white d-flex justify-content-between">
                                <h5 class="mb-0">{{ zone.name }}</h5>
                                <span class="badge bg-primary">{{ zone.deliveryPrice }} FCFA</span>
                            </div>
                            <div class="card-body">
                                <ul class="list-group list-group-flush">
                                    {% set zone_orders = orders|filter(o => o.zone and o.zone.id == zone.id) %}
                                    {% for order in zone_orders %}
                                        <li class="list-group-item d-flex flex-column gap-2 p-3">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <h6 class="mb-0">#{{ order.id }} - {{ order.user ? (order.user.firstName ~ ' ' ~ order.user.lastName) : 'Client' }}</h6>
                                                    <small class="text-muted">{{ order.totalAmount }} FCFA</small>
                                                </div>
                                                <a href="{{ path('app_order_show', {id: order.id}) }}" class="btn btn-sm btn-outline-info">Détails</a>
                                            </div>
                                            
                                            <form action="{{ path('app_delivery_assign', {id: order.id}) }}" method="post" class="d-flex gap-2">
                                                <select name="livreur_id" class="form-select form-select-sm" required>
                                                    <option value="">Choisir un livreur...</option>
                                                    {% for livreur in livreurs %}
                                                        <option value="{{ livreur.id }}">{{ livreur.firstName }} {{ livreur.lastName }}</option>
                                                    {% endfor %}
                                                </select>
                                                <button type="submit" class="btn btn-sm btn-primary">Assigner</button>
                                            </form>
                                        </li>
                                    {% else %}
                                        <li class="list-group-item text-muted text-center italic">Aucune commande en attente pour cette zone.</li>
                                    {% endfor %}
                                </ul>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12 text-center py-5">
                        <p class="text-muted">Aucune zone configurée.</p>
                    </div>
                {% endfor %}
            </div>
        </main>
    </div>
</div>
{% endblock %}
