{% extends 'base.html.twig' %}

{% block title %}Gestion des Commandes{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Gestion des Commandes</h1>
    
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Client</th>
                <th>Type</th>
                <th>État</th>
                <th>Montant</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for order in orders %}
            <tr>
                <td>{{ order.id }}</td>
                <td>{{ order.clientId }}</td>
                <td>{{ order.typeLivraison }}</td>
                <td>{{ order.etat }}</td>
                <td>{{ order.montantTotal }} FCFA</td>
                <td>{{ order.dateCommande|date('d/m/Y H:i') }}</td>
                <td>
                    <a href="{{ path('app_order_show', {id: order.id}) }}" class="btn btn-sm btn-primary">Voir</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
