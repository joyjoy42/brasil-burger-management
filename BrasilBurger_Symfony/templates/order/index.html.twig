{% extends 'base.html.twig' %}

{% block title %}Gestion des Commandes{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row">
        <!-- Sidebar (Reuse from dashboard or include) -->
        <nav class="col-md-3 col-lg-2 d-md-block bg-light sidebar collapse shadow-sm">
            <div class="position-sticky pt-3">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_dashboard') }}">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="{{ path('app_order_index') }}">
                            <i class="bi bi-bag"></i> Commandes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_delivery_index') }}">
                            <i class="bi bi-truck"></i> Livraisons
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_stats_index') }}">
                            <i class="bi bi-graph-up"></i> Statistiques
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_catalog_index') }}">
                            <i class="bi bi-journal-list"></i> Catalogue
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Liste des Commandes</h1>
            </div>

            <!-- Filters -->
            <form method="get" class="row g-3 mb-4">
                <div class="col-auto">
                    <select name="status" class="form-select">
                        <option value="">Tous les statuts</option>
                        <option value="en_attente" {{ current_status == 'en_attente' ? 'selected' : '' }}>En attente</option>
                        <option value="valide" {{ current_status == 'valide' ? 'selected' : '' }}>Validée</option>
                        <option value="annule" {{ current_status == 'annule' ? 'selected' : '' }}>Annulée</option>
                        <option value="termine" {{ current_status == 'termine' ? 'selected' : '' }}>Terminée</option>
                    </select>
                </div>
                <div class="col-auto">
                    <input type="date" name="date" class="form-control" value="{{ current_date }}">
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">Filtrer</button>
                    <a href="{{ path('app_order_index') }}" class="btn btn-outline-secondary">Réinitialiser</a>
                </div>
            </form>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Date</th>
                            <th>Client</th>
                            <th>Type</th>
                            <th>Montant</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for order in orders %}
                            <tr>
                                <td>#{{ order.id }}</td>
                                <td>{{ order.createdAt|date('d/m/Y H:i') }}</td>
                                <td>{{ order.user ? (order.user.firstName ~ ' ' ~ order.user.lastName) : 'Anonyme' }}</td>
                                <td>
                                    <span class="badge bg-info text-dark">{{ order.type|capitalize }}</span>
                                </td>
                                <td>{{ order.totalAmount }} FCFA</td>
                                <td>
                                    {% if order.status == 'en_attente' %}
                                        <span class="badge bg-warning text-dark">En attente</span>
                                    {% elseif order.status == 'valide' %}
                                        <span class="badge bg-success">Validée</span>
                                    {% elseif order.status == 'annule' %}
                                        <span class="badge bg-danger">Annulée</span>
                                    {% else %}
                                        <span class="badge bg-secondary">Terminée</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <a href="{{ path('app_order_show', {id: order.id}) }}" class="btn btn-sm btn-outline-primary">Détails</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center py-4">Aucune commande trouvée.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</div>
{% endblock %}
