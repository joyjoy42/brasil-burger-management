{% extends 'base.html.twig' %}

{% block title %}Détails de la commande #{{ order.id }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row">
        <!-- Sidebar -->
        <nav class="col-md-3 col-lg-2 d-md-block bg-light sidebar collapse shadow-sm">
            <div class="position-sticky pt-3">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_dashboard') }}">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="{{ path('app_order_index') }}">
                            <i class="bi bi-bag"></i> Commandes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_delivery_index') }}">
                            <i class="bi bi-truck"></i> Livraisons
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_stats_index') }}">
                            <i class="bi bi-graph-up"></i> Statistiques
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_catalog_index') }}">
                            <i class="bi bi-journal-list"></i> Catalogue
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Commande #{{ order.id }}</h1>
                <a href="{{ path('app_order_index') }}" class="btn btn-outline-secondary">Retour à la liste</a>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            <div class="row">
                <!-- Info Section -->
                <div class="col-md-8">
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-white">
                            <h5 class="mb-0">Articles commandés</h5>
                        </div>
                        <div class="card-body">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Produit</th>
                                        <th>Prix Unitaire</th>
                                        <th>Quantité</th>
                                        <th class="text-end">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for item in order.orderItems %}
                                        <tr>
                                            <td>
                                                {% if item.burger %}
                                                    {{ item.burger.name }} (Burger)
                                                {% elseif item.menu %}
                                                    {{ item.menu.name }} (Menu)
                                                {% elseif item.complement %}
                                                    {{ item.complement.name }} (Complément)
                                                {% endif %}
                                            </td>
                                            <td>{{ item.unitPrice }} FCFA</td>
                                            <td>{{ item.quantity }}</td>
                                            <td class="text-end">{{ item.unitPrice * item.quantity }} FCFA</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                                <tfoot>
                                    <tr class="fw-bold fs-5">
                                        <td colspan="3" class="text-end">Montant Total :</td>
                                        <td class="text-end">{{ order.totalAmount }} FCFA</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Status & Client Section -->
                <div class="col-md-4">
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-white">
                            <h5 class="mb-0">Informations Client</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Nom :</strong> {{ order.user ? (order.user.firstName ~ ' ' ~ order.user.lastName) : 'Anonyme' }}</p>
                            <p><strong>Type :</strong> {{ order.type|capitalize }}</p>
                            {% if order.zone %}
                                <p><strong>Zone de Livraison :</strong> {{ order.zone.name }} (+{{ order.zone.deliveryPrice }} FCFA)</p>
                            {% endif %}
                        </div>
                    </div>

                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-white">
                            <h5 class="mb-0">Modifier le statut</h5>
                        </div>
                        <div class="card-body">
                            <form action="{{ path('app_order_update_status', {id: order.id}) }}" method="post">
                                <div class="mb-3">
                                    <select name="status" class="form-select">
                                        <option value="en_attente" {{ order.status == 'en_attente' ? 'selected' : '' }}>En attente</option>
                                        <option value="valide" {{ order.status == 'valide' ? 'selected' : '' }}>Validée</option>
                                        <option value="annule" {{ order.status == 'annule' ? 'selected' : '' }}>Annulée</option>
                                        <option value="termine" {{ order.status == 'termine' ? 'selected' : '' }}>Terminée</option>
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-primary w-100">Mettre à jour</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}
