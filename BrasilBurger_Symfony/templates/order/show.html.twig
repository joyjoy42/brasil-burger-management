{% extends 'base.html.twig' %}

{% block title %}Commande #{{ order.id }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Commande #{{ order.id }}</h1>
    
    <p><strong>Client:</strong> {{ order.clientId }}</p>
    <p><strong>Type:</strong> {{ order.typeLivraison }}</p>
    <p><strong>État:</strong> {{ order.etat }}</p>
    <p><strong>Montant:</strong> {{ order.montantTotal }} FCFA</p>
    <p><strong>Date:</strong> {{ order.dateCommande|date('d/m/Y H:i') }}</p>
    
    <form method="post" action="{{ path('app_order_update_status', {id: order.id}) }}">
        <select name="status" class="form-control">
            <option value="en_attente">En attente</option>
            <option value="valide">Validé</option>
            <option value="termine">Terminé</option>
            <option value="annule">Annulé</option>
        </select>
        <button type="submit" class="btn btn-primary mt-2">Mettre à jour</button>
    </form>
    
    <a href="{{ path('app_order_index') }}" class="btn btn-secondary mt-3">Retour</a>
</div>
{% endblock %}
